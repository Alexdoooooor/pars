[Unit]
Description=Price Intelligence Parser Service
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/pars
EnvironmentFile=/var/www/pars/.env
ExecStart=/usr/bin/python3 -m uvicorn parser_service.main:app --host 127.0.0.1 --port 8810
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
